{
  "name": "@use-lattice/litmus",
  "description": "LLM eval & testing toolkit",
  "author": "Nithin Srinivasan",
  "version": "0.121.3",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/use-lattice/litmus.git"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.cjs"
    }
  },
  "types": "dist/src/index.d.ts",
  "typings": "dist/src/index.d.ts",
  "files": [
    "dist",
    "drizzle",
    "!dist/**/*.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  },
  "scripts": {
    "build:clean": "shx rm -rf dist",
    "build:watch": "NODE_OPTIONS='--max-old-space-size=8192' tsdown --watch",
    "build": "concurrently -g --kill-others-on-fail \"tsc --noEmit\" \"NODE_OPTIONS='--max-old-space-size=8192' tsdown\"",
    "postbuild": "tsx scripts/postbuild.ts",
    "lint:ci": "npx @biomejs/biome ci .",
    "lint:src": "npx @biomejs/biome lint src",
    "lint": "npm run lint:src",
    "format:check": "npx @biomejs/biome check",
    "format": "npx @biomejs/biome check --write .",
    "check": "npx @biomejs/biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "overrides": {
    "uri-js": "npm:uri-js-replace",
    "chokidar": "5.0.0",
    "whatwg-url": "16.0.1",
    "esbuild": "0.27.4",
